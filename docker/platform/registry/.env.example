# and https://github.com/Joxit/docker-registry-ui/releases for latest tags)
REGISTRY_VERSION=3.1.1
REGISTRY_UI_VERSION=2.6.0

# Title shown in the registry UI
REGISTRY_UI_TITLE=Container Registry
